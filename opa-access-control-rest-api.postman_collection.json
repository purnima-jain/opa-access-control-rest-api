  "item": [
    {
      "name": "Inject Policy",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "package app.rbac\r\n\r\n# By default, deny requests.\r\ndefault allow := false\r\n\r\n# Allow admins to do anything.\r\nallow if user_is_admin\r\n\r\n# Allow the action if the user is granted permission to perform the action.\r\nallow if {\r\n\t# Find grants for the user.\r\n\tsome grant in user_is_granted\r\n\r\n\t# Check if the grant permits the action.\r\n\tinput.action == grant.action\r\n\tinput.type == grant.type\r\n}\r\n\r\n# user_is_admin is true if \"admin\" is among the user's roles as per data.user_roles\r\nuser_is_admin if \"admin\" in data.user_roles[input.user]\r\n\r\n# user_is_granted is a set of grants for the user identified in the request.\r\n# The `grant` will be contained if the set `user_is_granted` for every...\r\nuser_is_granted contains grant if {\r\n\t# `role` assigned an element of the user_roles for this user...\r\n\tsome role in data.user_roles[input.user]\r\n\r\n\t# `grant` assigned a single grant from the grants list for 'role'...\r\n\tsome grant in data.role_grants[role]\r\n}",
          "options": {
            "raw": {
              "language": "text"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8181/v1/policies/example1",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8181",
          "path": [
            "v1",
            "policies",
            "example1"
          ]
        }
      },
      "response": []
    },
